NODE_ENV=development
ENVIRONMENT=development
PORT=3000
BACKEND_PORT=3000
FRONTEND_PORT=8080

# Database - use service hostname postgres inside docker-compose, not localhost
DATABASE_URL=postgresql://leanstock:leanstock_password@postgres:5432/leanstock?schema=public

# Redis - used for rate limiting, locks and BullMQ background jobs
REDIS_URL=redis://redis:6379

# JWT - minimum 32 characters. JWT_SECRET_KEY names are included because the final assignment names them this way.
JWT_SECRET_KEY=change_me_access_secret_minimum_32_characters
JWT_REFRESH_SECRET_KEY=change_me_refresh_secret_minimum_32_characters
JWT_ACCESS_SECRET=change_me_access_secret_minimum_32_characters
JWT_REFRESH_SECRET=change_me_refresh_secret_minimum_32_characters
JWT_ACCESS_EXPIRES_IN=15m
REFRESH_TOKEN_DAYS=7

# Auth/email token lifetimes
EMAIL_VERIFICATION_TOKEN_MINUTES=30
PASSWORD_RESET_TOKEN_MINUTES=15
RESERVATION_TTL_MINUTES=15

# CORS - comma-separated allowed origins, no wildcard in production
CORS_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:3000

# Public backend URL used by API and health/docs links
APP_BASE_URL=http://localhost:3000

# Public frontend URL used inside password reset email links
# Password reset links use FRONTEND_BASE_URL. Email verification messages include both a backend verify link and a copyable token.
FRONTEND_BASE_URL=http://localhost:8080

# Background workers
ENABLE_WORKER=true
DEAD_STOCK_CRON_MINUTES=60
DEAD_STOCK_AGE_DAYS=30
DEAD_STOCK_DECAY_PERCENT=10
DEAD_STOCK_DECAY_INTERVAL_HOURS=72

# Email provider: mock | resend | smtp
# For defense and production use REAL email delivery. mock is allowed only for automated tests.
EMAIL_PROVIDER=smtp
EMAIL_FROM=LeanStock <your_email@gmail.com>
EMAIL_FROM_ADDRESS=your_email@gmail.com
EMAIL_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password_without_spaces
EMAIL_QUEUE_ATTEMPTS=3

# Local key required only for POST /auth/register-super-admin
SUPERADMIN_SETUP_KEY=local-super-admin-setup-key
